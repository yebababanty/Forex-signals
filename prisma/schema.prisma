generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Signal {
  id                 String   @id @default(cuid())
  pair               String
  direction          String
  timeframe          String
  confidence         Int
  entry              Float
  stopLoss           Float
  tp1                Float
  tp2                Float
  tp3                Float
  riskReward         String   @default("1:2")
  bias               String   @db.Text
  marketContext      String   @db.Text
  supportingFactors  Json
  riskFactors        Json
  strategyChecklist  Json
  chartImageUrl      String?
  status             String   @default("active")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([pair])
  @@index([status])
  @@index([createdAt])
}
